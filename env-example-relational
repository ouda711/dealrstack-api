NODE_ENV=development
APP_PORT=3001
APP_NAME="DealrStack API"
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_HEADER_LANGUAGE=x-custom-lang
FRONTEND_DOMAIN=http://localhost:3000
BACKEND_DOMAIN=http://localhost:3001

DATABASE_TYPE=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_HOST_PORT=5433
DATABASE_USERNAME=root
DATABASE_PASSWORD=secret
DATABASE_NAME=dealrstack
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=
DATABASE_URL=

# Support "local", "s3", "s3-presigned"
FILE_DRIVER=local
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
AWS_S3_REGION=
AWS_DEFAULT_S3_BUCKET=

# Optional CDN or virtual host base for public URLs after S3 upload (no trailing slash)
FILE_PUBLIC_BASE_URL=

MAIL_HOST=maildev
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_IGNORE_TLS=true
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false
MAIL_DEFAULT_EMAIL=noreply@dealrstack.com
MAIL_DEFAULT_NAME=DealrStack
MAIL_CLIENT_PORT=1080

AUTH_JWT_SECRET=secret
AUTH_JWT_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_SECRET=secret_for_refresh
AUTH_REFRESH_TOKEN_EXPIRES_IN=3650d
AUTH_FORGOT_SECRET=secret_for_forgot
AUTH_FORGOT_TOKEN_EXPIRES_IN=30m
AUTH_CONFIRM_EMAIL_SECRET=secret_for_confirm_email
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Meta WhatsApp Cloud API (DealrStack app — shared webhook + per-tenant tokens)
WHATSAPP_API_VERSION=v21.0
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=
# Optional override; defaults to {FRONTEND_DOMAIN}/workspace/conversations/whatsapp-callback
WHATSAPP_OAUTH_REDIRECT_URI=
# Optional: wire demo tenant when running seeds (each real tenant connects via PUT /whatsapp-integration)
WHATSAPP_DEMO_TENANT_SLUG=nairobi-auto-hub
WHATSAPP_DEMO_PHONE_NUMBER_ID=
WHATSAPP_DEMO_ACCESS_TOKEN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APPLE_APP_AUDIENCE=[]

WORKER_HOST=redis://redis:6379/1

# AI — DeepSeek default when keys exist; otherwise first available provider (OpenAI/Gemini).
# OPEN_AI / OPEN_AI_API_KEY are aliases for OPENAI_API_KEY (same for OPEN_AI_MODEL ↔ OPENAI_MODEL).
AI_TEXT_PRIMARY_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=
OPEN_AI=
OPEN_AI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPEN_AI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
AI_IMAGE_PRIMARY_PROVIDER=gemini
OPENAI_IMAGE_MODEL=dall-e-3

# Generic JSON settings (GET/PUT /v1/settings/:name — requires platform.manage).
# Prefer storing secrets here instead of .env. AI merges DB row `ai_config` over env defaults.
#
# PUT /v1/settings/ai_config
# {"textPrimaryProvider":"deepseek","deepseek":{"apiKey":"…","model":"deepseek-chat"},"openai":{"apiKey":"…"},"gemini":{"apiKey":"…","imageModel":"gemini-2.5-flash-image"}}
#
# Other integrations can use arbitrary JSON names (e.g. settlement_config) with nested JSON like your settlement maps.

# Vehicle marketing flyer SSE — POST …/marketing/flyer-threads/:threadId/stream
# TTL/limit apply only to that route (in-memory counter per IP).
FLYER_STREAM_THROTTLE_TTL_MS=60000
FLYER_STREAM_THROTTLE_LIMIT=30
