<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>{{title}}</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.5; color: #111;">
  <h2 style="margin-bottom: 8px;">{{title}}</h2>
  <p style="margin-top: 0;">{{body}}</p>
  {{#if actionUrl}}
  <p>
    <a href="{{actionUrl}}" style="display:inline-block;padding:10px 16px;background:#16a34a;color:#fff;text-decoration:none;border-radius:6px;">
      Open in DealrStack
    </a>
  </p>
  {{/if}}
  <p style="font-size: 12px; color: #666;">{{app_name}} sales workspace alert</p>
</body>
</html>
